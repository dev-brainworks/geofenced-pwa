{

  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/manifest.webmanifest", "destination": "dist/geofence-attendance-pwa/browser/manifest.webmanifest" },
    { "source": "/offline.html", "destination": "dist/geofence-attendance-pwa/browser/offline.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
