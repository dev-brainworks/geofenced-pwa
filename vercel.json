{

  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    {
      "src": "/manifest.webmanifest",
      "dest": "/manifest.webmanifest",
      "headers": {
        "key": "Content-Type",
        "value": "application/manifest+json"
      },
      "continue": false
    },
    {
      "src": "/.well-known/assetlinks.json",
      "dest": "/.well-known/assetlinks.json",
      "continue": false
    },
    {
      "src": "/offline.html",
      "dest": "/offline.html",
      "continue": false
    },
    {
      "src": "/(.*)\\.(js|css|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot|webmanifest)$",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
