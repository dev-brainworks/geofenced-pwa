{

  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(.*\\.)?(json|webmanifest|xml|txt|js|css|ico|jpg|jpeg|gif|png|svg|woff|woff2|ttf|eot)$",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        },
        {
          "key": "x-vercel-protection-bypass",
          "value": "G6qtzfh5NQraeOjuI8VYVKg6dcTAFLve"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/manifest.webmanifest",
      "dest": "/manifest.webmanifest",
      "headers": {
        "key": "Content-Type",
        "value": "application/manifest+json"
      },
      "continue": false
    },
    {
      "src": "/.well-known/assetlinks.json",
      "dest": "/.well-known/assetlinks.json",
      "continue": false
    },
    {
      "src": "/offline.html",
      "dest": "/offline.html",
      "continue": false
    },
    {
      "src": "/(.*)\\.(js|css|ico|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot|webmanifest|json)$",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
