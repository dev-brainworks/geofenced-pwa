.vendor-login-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40px;
}

.vendor-login-card {
  text-align: center;
  width: fit-content;
  padding: 20px;
}

.image-container {
  position: relative;
  display: inline-block;
}

.image-container img {
  width: 80vw;
  height: auto;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
}

.login-overlay {
  position: absolute;
  top: 0;
  left: 54%;
  width: 35vw;
}

.vendor-login-form {
  display: flex;
  flex-direction: column;
  margin: 40px auto;
  padding: 20px;

  mat-form-field {
    width: 100%;
    margin-bottom: 16px;
  }

  button {
    width: 100%;
  }
}


